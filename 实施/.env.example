# ============================================
# Provider 选择（minimax / anthropic）
# 默认 minimax 跑（成本低，约 Anthropic Opus 的 1/100）
# ============================================
LLM_PROVIDER=minimax

# ============================================
# MiniMax 配置（默认 provider）
# 申请：https://platform.minimaxi.com/
# ============================================
MINIMAX_API_KEY=PASTE-YOUR-MINIMAX-KEY-HERE
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# ============================================
# Anthropic 配置（备选 provider，做最终对比时用）
# 申请：https://console.anthropic.com/
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-PASTE-YOUR-KEY-HERE
ANTHROPIC_MODEL=claude-opus-4-7
